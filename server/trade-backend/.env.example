# Copy to .env and fill in real values. MySQL must be running and the database must exist.

PORT=5000
JWT_SECRET=change-this-to-a-long-random-string

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=haf_trade

# Optional pool tuning
# DB_CONN_LIMIT=8
# DB_MAX_IDLE=5
# DB_IDLE_TIMEOUT=60000
