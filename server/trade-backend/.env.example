# Copy to .env and fill in real values. MySQL must be running and the database must exist.

PORT=5000
JWT_SECRET=change-this-to-a-long-random-string

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=haf_trade

# Comma-separated allowed frontend origins (production). Example:
# CORS_ORIGIN=https://haf-web.onrender.com
CORS_ORIGIN=
FRONTEND_URL=

# Optional pool tuning
# DB_CONN_LIMIT=8
# DB_MAX_IDLE=5
# DB_IDLE_TIMEOUT=60000
